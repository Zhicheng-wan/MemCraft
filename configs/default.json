    "agent": {
        "max_steps": 100,
        "action_timeout_seconds": 10,
        "observation_interval_ms": 500
    },
    "mineflayer": {
        "host": "localhost",
        "port": 25565,
        "username": "MemAgent",
        "version": "1.20.4"
    }
}
